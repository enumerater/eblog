<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.enumerate.intelligence.mapper.AnalysisMapper">

    <resultMap id="analysisResultMap" type="com.enumerate.intelligence.entity.ArticleAnalysis">
        <id property="id" column="id"/>
        <result property="articleId" column="article_id"/>
        <result property="summary" column="summary"/>
        <result property="keywords" column="keywords"/>
        <result property="wordCount" column="word_count"/>
        <result property="readingTimeMinutes" column="reading_time_minutes"/>
        <result property="analyzedAt" column="analyzed_at"/>
    </resultMap>

    <select id="findByArticleId" resultMap="analysisResultMap">
        SELECT * FROM article_analysis WHERE article_id = #{articleId}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO article_analysis (article_id, summary, keywords, word_count, reading_time_minutes, analyzed_at)
        VALUES (#{articleId}, #{summary}, #{keywords}, #{wordCount}, #{readingTimeMinutes}, NOW())
    </insert>

    <update id="update">
        UPDATE article_analysis
        SET summary = #{summary}, keywords = #{keywords},
            word_count = #{wordCount}, reading_time_minutes = #{readingTimeMinutes},
            analyzed_at = NOW()
        WHERE article_id = #{articleId}
    </update>

    <delete id="deleteByArticleId">
        DELETE FROM article_analysis WHERE article_id = #{articleId}
    </delete>

    <select id="findArticlesForRecommendation" resultType="map">
        SELECT id, tags_json FROM articles WHERE id != #{articleId}
    </select>

    <select id="findAllArticleIdsAndTags" resultType="map">
        SELECT id, tags_json FROM articles
    </select>

</mapper>