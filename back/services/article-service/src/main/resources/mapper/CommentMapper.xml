<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.enumerate.article.mapper.CommentMapper">

    <resultMap id="commentResultMap" type="com.enumerate.article.entity.Comment">
        <id property="id" column="id"/>
        <result property="articleId" column="article_id"/>
        <result property="author" column="author"/>
        <result property="content" column="content"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="findByArticleId" resultMap="commentResultMap">
        SELECT id, article_id, author, content, created_at
        FROM comments
        WHERE article_id = #{articleId}
        ORDER BY created_at ASC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO comments (article_id, author, content, created_at)
        VALUES (#{articleId}, #{author}, #{content}, NOW())
    </insert>

    <delete id="deleteById">
        DELETE FROM comments WHERE id = #{id}
    </delete>

    <delete id="deleteByArticleId">
        DELETE FROM comments WHERE article_id = #{articleId}
    </delete>

</mapper>